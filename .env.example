# Copy to `.env.local` and adjust if needed (never commit real secrets).

# PostgreSQL must already be installed and running on your Mac (see README).
# Example: database named `docsync` on the default port (adjust user if needed).
DATABASE_URL=postgresql://localhost:5432/docsync

# Signing key for session cookies (HS256). Use a long random string (32+ characters).
AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
